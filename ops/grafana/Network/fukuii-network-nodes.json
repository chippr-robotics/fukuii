        "name": "job",
        "type": "query",
        "datasource": "Prometheus",
        "definition": "label_values(app_network_peer_info, job)",
        "query": {
          "query": "label_values(app_network_peer_info, job)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1,
        "current": {
          "text": "fukuii-primary",
          "value": "fukuii-primary"
        },
        "options": [],
        "hide": 0
      }
    ]
  },
