{
 "uid": "fukuii-peer-map",
 "title": "Fukuii Peer Node Map",
 "schemaVersion": 38,
 "version": 1,
 "editable": true,
 "timezone": "",
 "time": {
  "from": "now-15m",
  "to": "now"
 },
 "refresh": "30s",
 "tags": [
  "fukuii",
  "network",
  "peers"
 ],
 "templating": {
  "list": []
 },
 "panels": [
  {
   "type": "geomap",
   "title": "Peer Node Map (active discovery + connections)",
   "id": 1,
   "gridPos": {
    "h": 15,
    "w": 18,
    "x": 0,
    "y": 0
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "fukuii_peer_location",
     "format": "table",
     "instant": true,
     "refId": "A"
    }
   ],
   "transformations": [
    {
     "id": "labelsToFields",
     "options": {}
    },
    {
     "id": "convertFieldType",
     "options": {
      "conversions": [
       {
        "targetField": "latitude",
        "destinationType": "number"
       },
       {
        "targetField": "longitude",
        "destinationType": "number"
       }
      ]
     }
    }
   ],
   "options": {
    "view": {
     "id": "fit",
     "lat": 25,
     "lon": 10,
     "zoom": 1.8
    },
    "basemap": {
     "type": "default",
     "name": "Basemap"
    },
    "controls": {
     "showZoom": true,
     "mouseWheelZoom": true,
     "showAttribution": true,
     "showScale": false,
     "showMeasure": false,
     "showDebug": false
    },
    "tooltip": {
     "mode": "details"
    },
    "layers": [
     {
      "type": "markers",
      "name": "Peers",
      "location": {
       "mode": "coords",
       "latitude": "latitude",
       "longitude": "longitude"
      },
      "config": {
       "showLegend": false,
       "style": {
        "size": {
         "fixed": 5,
         "min": 2,
         "max": 10
        },
        "color": {
         "fixed": "semi-dark-blue"
        },
        "opacity": 0.55,
        "symbol": {
         "mode": "fixed",
         "fixed": "img/icons/marker/circle.svg"
        }
       }
      },
      "tooltip": true
     }
    ]
   },
   "fieldConfig": {
    "defaults": {},
    "overrides": []
   }
  },
  {
   "type": "stat",
   "title": "Peers Mapped",
   "id": 2,
   "gridPos": {
    "h": 5,
    "w": 6,
    "x": 18,
    "y": 0
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "fukuii_peer_total",
     "refId": "A",
     "instant": true
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "none",
     "decimals": 0,
     "color": {
      "mode": "fixed",
      "fixedColor": "green"
     }
    }
   },
   "options": {
    "colorMode": "background",
    "graphMode": "none",
    "textMode": "value",
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ],
     "fields": "",
     "values": false
    }
   }
  },
  {
   "type": "stat",
   "title": "Countries",
   "id": 3,
   "gridPos": {
    "h": 5,
    "w": 6,
    "x": 18,
    "y": 5
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "count(fukuii_peers_by_country)",
     "refId": "A",
     "instant": true
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "none",
     "decimals": 0,
     "color": {
      "mode": "fixed",
      "fixedColor": "purple"
     }
    }
   },
   "options": {
    "colorMode": "background",
    "graphMode": "none",
    "textMode": "value",
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ],
     "fields": "",
     "values": false
    }
   }
  },
  {
   "type": "stat",
   "title": "Located / Discovered",
   "id": 4,
   "gridPos": {
    "h": 5,
    "w": 6,
    "x": 18,
    "y": 10
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "fukuii_peer_located",
     "refId": "A",
     "instant": true
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "none",
     "decimals": 0,
     "color": {
      "mode": "fixed",
      "fixedColor": "blue"
     }
    }
   },
   "options": {
    "colorMode": "background",
    "graphMode": "none",
    "textMode": "value",
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ],
     "fields": "",
     "values": false
    }
   }
  },
  {
   "type": "bargauge",
   "title": "Peers by Country (top 15)",
   "id": 5,
   "gridPos": {
    "h": 9,
    "w": 24,
    "x": 0,
    "y": 15
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "expr": "topk(15, fukuii_peers_by_country)",
     "refId": "A",
     "instant": true,
     "legendFormat": "{{country}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "none",
     "decimals": 0,
     "color": {
      "mode": "continuous-BlPu"
     }
    }
   },
   "options": {
    "orientation": "horizontal",
    "displayMode": "gradient",
    "showUnfilled": true,
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ],
     "fields": "",
     "values": false
    }
   }
  }
 ]
}