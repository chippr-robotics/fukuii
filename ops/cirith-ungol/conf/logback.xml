<configuration>

    <property name="stdoutEncoderPattern" value="%d %-5level [%logger{36}] - %msg%n" />
    <property name="fileEncoderPattern" value="%d [%thread] %-5level %logger{36} %X{akkaSource} - %msg%n" />

    <!--read properties from application.conf using PropertyDefiner (logback 1.5.x compatible)-->
    <define name="LOGSLEVEL" class="com.chipprbots.ethereum.utils.ConfigPropertyDefiner">
        <key>logging.logs-level</key>
        <defaultValue>WARN</defaultValue>
    </define>
    <define name="ASJSON" class="com.chipprbots.ethereum.utils.ConfigPropertyDefiner">
        <key>logging.json-output</key>
        <defaultValue>false</defaultValue>
    </define>
    <define name="LOGSDIR" class="com.chipprbots.ethereum.utils.ConfigPropertyDefiner">
        <key>logging.logs-dir</key>
        <defaultValue>./logs</defaultValue>
    </define>
    <define name="LOGSFILENAME" class="com.chipprbots.ethereum.utils.ConfigPropertyDefiner">
        <key>logging.logs-file</key>
        <defaultValue>fukuii</defaultValue>
    </define>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${stdoutEncoderPattern}</pattern>
        </encoder>
    </appender>

    <appender name="STASH" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service":"fukuii","node":"${FUKUII_NODE_ID:-${HOSTNAME}}","environment":"${FUKUII_ENV:-production}"}</customFields>
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <version>[ignore]</version>
                <logger>logger</logger>
                <thread>thread</thread>
                <level>level</level>
                <levelValue>level_value</levelValue>
                <message>message</message>
                <stackTrace>stack_trace</stackTrace>
            </fieldNames>
            <includeCallerData>false</includeCallerData>
            <includeContext>true</includeContext>
        </encoder>
    </appender>

    <appender name="METRICS" class="io.prometheus.client.logback.InstrumentedAppender" />

    <root level="${LOGSLEVEL}">
        <if condition='p("ASJSON").contains("true")'>
            <then>
                <appender-ref ref="STASH" />
            </then>
            <else>
                <appender-ref ref="STDOUT" />
            </else>
        </if>
        <appender-ref ref="METRICS" />
    </root>

    <!-- =================================================================== -->
    <!-- WIRE-LEVEL COMMUNICATION DIAGNOSTICS                                -->
    <!-- =================================================================== -->
    <!--
         Focus: Why do ALL peers stop responding after ~20 seconds?
         Goal: See if messages are written to socket, if responses arrive,
         and whether responses are routed correctly to request handlers.
    -->

    <!-- =================================================================== -->
    <!-- EXTERNAL LIBRARIES (WARN — only problems)                           -->
    <!-- =================================================================== -->
    <logger name="io.netty" level="WARN"/>
    <logger name="org.jupnp.QueueingThreadPoolExecutor" level="WARN" />
    <logger name="org.jupnp.util.SpecificationViolationReporter" level="ERROR" />
    <logger name="org.jupnp.protocol.RetrieveRemoteDescriptors" level="ERROR" />

    <!-- Pekko dead-letters — INFO to catch message delivery issues -->
    <logger name="org.apache.pekko.actor.LocalActorRef" level="INFO" />

    <!-- =================================================================== -->
    <!-- SCALANET — Low-level networking (WARN only)                         -->
    <!-- =================================================================== -->
    <logger name="com.chipprbots.scalanet" level="WARN" />

    <!-- =================================================================== -->
    <!-- NETWORK — DEBUG for PeerActor to see message send/receive           -->
    <!-- =================================================================== -->
    <logger name="com.chipprbots.ethereum.network" level="WARN" />
    <logger name="com.chipprbots.ethereum.network.PeerActor" level="DEBUG" />
    <logger name="com.chipprbots.ethereum.network.PeerManagerActor" level="INFO" />
    <logger name="com.chipprbots.ethereum.network.NetworkPeerManagerActor" level="INFO" />
    <logger name="com.chipprbots.ethereum.network.PeerEventBusActor" level="INFO" />
    <logger name="com.chipprbots.ethereum.network.ServerActor" level="INFO" />
    <logger name="com.chipprbots.ethereum.network.KnownNodesManager" level="WARN" />

    <!-- Discovery — INFO to see peer discovery lifecycle -->
    <logger name="com.chipprbots.ethereum.network.discovery" level="INFO" />
    <logger name="com.chipprbots.ethereum.network.discovery.PeerDiscoveryManager" level="DEBUG" />
    <logger name="com.chipprbots.ethereum.network.discovery.DiscoveryServiceBuilder" level="INFO" />

    <!-- Handshaking — INFO to see handshake results -->
    <logger name="com.chipprbots.ethereum.network.handshaker" level="INFO" />

    <!-- ForkId — INFO to see compatibility issues with peers -->
    <logger name="com.chipprbots.ethereum.forkid" level="INFO" />

    <!-- =================================================================== -->
    <!-- RLPX — DEBUG for wire-level message flow                            -->
    <!-- =================================================================== -->
    <logger name="com.chipprbots.ethereum.network.rlpx" level="DEBUG" />
    <logger name="com.chipprbots.ethereum.network.rlpx.RLPxConnectionHandler" level="DEBUG" />
    <logger name="com.chipprbots.ethereum.network.rlpx.FrameCodec" level="WARN" />
    <logger name="com.chipprbots.ethereum.network.rlpx.MessageCodec" level="WARN" />
    <logger name="com.chipprbots.ethereum.network.rlpx.AuthHandshaker" level="INFO" />

    <!-- =================================================================== -->
    <!-- SYNC CORE — INFO (reduce noise, focus on wire level)                -->
    <!-- =================================================================== -->
    <logger name="com.chipprbots.ethereum.blockchain.sync" level="INFO" />
    <logger name="com.chipprbots.ethereum.blockchain.sync.SyncController" level="INFO" />
    <logger name="com.chipprbots.ethereum.blockchain.sync.AdaptiveSyncStrategy" level="WARN" />
    <logger name="com.chipprbots.ethereum.blockchain.sync.PivotHeaderBootstrap" level="INFO" />

    <!-- Peer management — INFO for request/response tracking -->
    <logger name="com.chipprbots.ethereum.blockchain.sync.PeerRequestHandler" level="INFO" />
    <logger name="com.chipprbots.ethereum.blockchain.sync.PeersClient" level="INFO" />
    <logger name="com.chipprbots.ethereum.blockchain.sync.PeerListSupportNg" level="INFO" />
    <logger name="com.chipprbots.ethereum.blockchain.sync.Blacklist" level="INFO" />
    <logger name="com.chipprbots.ethereum.blockchain.sync.CacheBasedBlacklist" level="WARN" />
    <logger name="com.chipprbots.ethereum.blockchain.sync.BlockchainHostActor" level="WARN" />

    <!-- =================================================================== -->
    <!-- SNAP SYNC — INFO (reduce noise, focus on wire level)                -->
    <!-- =================================================================== -->
    <logger name="com.chipprbots.ethereum.blockchain.sync.snap" level="INFO" />
    <logger name="com.chipprbots.ethereum.blockchain.sync.snap.SNAPSyncController" level="INFO" />
    <logger name="com.chipprbots.ethereum.blockchain.sync.snap.actors" level="WARN" />
    <logger name="com.chipprbots.ethereum.blockchain.sync.snap.AccountRangeDownloader" level="WARN" />
    <logger name="com.chipprbots.ethereum.blockchain.sync.snap.StorageRangeDownloader" level="WARN" />
    <logger name="com.chipprbots.ethereum.blockchain.sync.snap.StorageRangeCoordinator" level="WARN" />
    <logger name="com.chipprbots.ethereum.blockchain.sync.snap.ByteCodeDownloader" level="WARN" />
    <logger name="com.chipprbots.ethereum.blockchain.sync.snap.TrieNodeHealer" level="WARN" />
    <logger name="com.chipprbots.ethereum.blockchain.sync.snap.MerkleProofVerifier" level="ERROR" />
    <logger name="com.chipprbots.ethereum.blockchain.sync.snap.SNAPRequestTracker" level="WARN" />
    <logger name="com.chipprbots.ethereum.blockchain.sync.snap.SyncProgressMonitor" level="INFO" />
    <logger name="com.chipprbots.ethereum.blockchain.sync.snap.SNAPErrorHandler" level="WARN" />

    <!-- =================================================================== -->
    <!-- FAST SYNC — WARN (not the focus)                                     -->
    <!-- =================================================================== -->
    <logger name="com.chipprbots.ethereum.blockchain.sync.fast" level="WARN" />

    <!-- =================================================================== -->
    <!-- REGULAR SYNC — WARN (not the focus)                                  -->
    <!-- =================================================================== -->
    <logger name="com.chipprbots.ethereum.blockchain.sync.regular" level="WARN" />

    <!-- =================================================================== -->
    <!-- LEDGER / DB / MPT / VM — WARN or OFF                                -->
    <!-- =================================================================== -->
    <logger name="com.chipprbots.ethereum.ledger" level="WARN" />
    <logger name="com.chipprbots.ethereum.db" level="WARN" />
    <logger name="com.chipprbots.ethereum.mpt" level="WARN" />
    <logger name="com.chipprbots.ethereum.vm" level="OFF" />
    <logger name="com.chipprbots.ethereum.vm.VM" level="OFF" />
    <logger name="com.chipprbots.ethereum.extvm" level="ERROR" />

    <!-- =================================================================== -->
    <!-- OTHER — Minimal noise                                                -->
    <!-- =================================================================== -->
    <logger name="com.chipprbots.ethereum.consensus" level="WARN" />
    <logger name="com.chipprbots.ethereum.transactions" level="WARN" />
    <logger name="com.chipprbots.ethereum.jsonrpc" level="WARN" />
    <logger name="com.chipprbots.ethereum.faucet" level="ERROR" />
    <logger name="com.chipprbots.ethereum.metrics" level="WARN" />

    <!-- Startup lifecycle — INFO for boot sequence -->
    <logger name="com.chipprbots.ethereum.blockchain.data" level="INFO" />
    <logger name="com.chipprbots.ethereum.blockchain.data.GenesisDataLoader" level="INFO" />
    <logger name="com.chipprbots.ethereum.blockchain.data.BootstrapCheckpointLoader" level="INFO" />
</configuration>
