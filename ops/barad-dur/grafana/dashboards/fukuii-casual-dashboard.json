      "pluginVersion": "7.3.6",
      "targets": [
        {
          "expr": "app_regularsync_blocks_imported_total{instance=~\"$node\"}",
          "interval": "",
          "legendFormat": "Blocks Imported",
          "refId": "A"
        }
      ],
      "title": "\ud83d\udce5 Blocks Imported",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "Pending transactions in mempool",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
