  "description": "Fukuii Steady-State Dashboard - At-a-glance node status for Barad-d\u00fbr",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "description": "Current synced block number (regular sync or fast sync best block)",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "pluginVersion": "7.3.6",
      "targets": [
        {
          "expr": "max(app_regularsync_block_current_number_gauge{instance=~\"$node\"} or app_fastsync_block_bestFullBlock_number_gauge{instance=~\"$node\"} or vector(0))",
          "interval": "",
          "legendFormat": "Block Height",
          "refId": "A"
        }
      ],
      "title": "\ud83d\udd17 Block Height",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "How many blocks behind the network head. 0 = fully synced.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": { "0": { "color": "#73BF69", "text": "Synced" } },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "id": 8,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "pluginVersion": "7.3.6",
      "targets": [
        {
          "expr": "clamp_min(app_regularsync_block_bestKnown_number_gauge{instance=~\"$node\"} - app_regularsync_block_current_number_gauge{instance=~\"$node\"}, 0)",
          "interval": "",
          "legendFormat": "Blocks Behind",
          "refId": "A"
        }
      ],
      "title": "\ud83c\udfaf Blocks Behind Head",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "Connected peers (incoming + outgoing)",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "green", "value": 10 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "pluginVersion": "7.3.6",
      "targets": [
        {
          "expr": "app_network_peers_incoming_handshaked_gauge{instance=~\"$node\"} + app_network_peers_outgoing_handshaked_gauge{instance=~\"$node\"}",
          "interval": "",
          "legendFormat": "Peers",
          "refId": "A"
        }
      ],
      "title": "\ud83d\udc65 Connected Peers",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "Current sync phase: Idle, SNAP sync (accounts/storage/bytecode/healing), or Regular Sync",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": {
                "0": { "color": "#73BF69", "text": "Idle" },
                "1": { "color": "#73BF69", "text": "SNAP: Accounts" },
                "2": { "color": "#3274D9", "text": "SNAP: ByteCode" },
                "3": { "color": "#FFB357", "text": "SNAP: Code+Storage" },
                "4": { "color": "#FFB357", "text": "SNAP: Storage" },
                "5": { "color": "#B877D9", "text": "SNAP: Healing" },
                "6": { "color": "#00D395", "text": "SNAP: Validation" },
                "7": { "color": "#FF6B9D", "text": "Chain Download" },
                "8": { "color": "#73BF69", "text": "Regular Sync" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#73BF69", "value": 1 },
              { "color": "#3274D9", "value": 2 },
              { "color": "#FFB357", "value": 3 },
              { "color": "#FFB357", "value": 4 },
              { "color": "#B877D9", "value": 5 },
              { "color": "#00D395", "value": 6 },
              { "color": "#FF6B9D", "value": 7 },
              { "color": "#73BF69", "value": 8 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "id": 9,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "pluginVersion": "7.3.6",
      "targets": [
        {
          "expr": "app_snapsync_phase_current_gauge{instance=~\"$node\"}",
          "interval": "",
          "legendFormat": "Phase",
          "refId": "A"
        }
      ],
      "title": "Sync Phase",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "JVM heap memory utilization",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 6 },
      "id": 4,
      "options": {
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "pluginVersion": "7.3.6",
      "targets": [
        {
          "expr": "jvm_memory_bytes_used{instance=~\"$node\", area=\"heap\"} / jvm_memory_bytes_max{instance=~\"$node\", area=\"heap\"} * 100",
          "interval": "",
          "legendFormat": "Memory %",
          "refId": "A"
        }
      ],
      "title": "\ud83d\udcbe Memory Usage",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "description": "Blocks imported by regular sync (cumulative)",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 6 },
      "id": 10,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
