{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Fukuii Fast Sync Dashboard - Monitor fast synchronization progress on ETC mainnet",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "datasource": "Prometheus",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Fast Sync Overview",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "description": "Best block header downloaded",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 1000000 }
            ]
          },
          "unit": "none"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        { "expr": "app_fastsync_block_bestHeader_number_gauge{instance=~\"$node\"}", "legendFormat": "Headers", "refId": "A" }
      ],
      "title": "Best Header",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "Best full block (headers + bodies + receipts)",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null },
              { "color": "green", "value": 1000000 }
            ]
          },
          "unit": "none"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        { "expr": "app_fastsync_block_bestFullBlock_number_gauge{instance=~\"$node\"}", "legendFormat": "Full Blocks", "refId": "A" }
      ],
      "title": "Best Full Block",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "Pivot block target for state download",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "purple", "value": null }
            ]
          },
          "unit": "none"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        { "expr": "app_fastsync_block_pivotBlock_number_gauge{instance=~\"$node\"}", "legendFormat": "Pivot", "refId": "A" }
      ],
      "title": "Pivot Block",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "Percentage of blocks downloaded (headers vs pivot)",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 25 },
              { "color": "green", "value": 75 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        { "expr": "app_fastsync_block_bestHeader_number_gauge{instance=~\"$node\"} / app_fastsync_block_pivotBlock_number_gauge{instance=~\"$node\"} * 100", "legendFormat": "Progress", "refId": "A" }
      ],
      "title": "Block Download %",
      "type": "stat"
    },
    {
      "collapsed": false,
      "datasource": "Prometheus",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 200,
      "panels": [],
      "title": "Block Download Progress",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "description": "Block download progress over time - headers, full blocks, and pivot target",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "Block Number",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Pivot" },
            "properties": [
              { "id": "custom.drawStyle", "value": "line" },
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 6 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "app_fastsync_block_bestHeader_number_gauge{instance=~\"$node\"}", "legendFormat": "Headers", "refId": "A" },
        { "expr": "app_fastsync_block_bestFullBlock_number_gauge{instance=~\"$node\"}", "legendFormat": "Full Blocks", "refId": "B" },
        { "expr": "app_fastsync_block_pivotBlock_number_gauge{instance=~\"$node\"}", "legendFormat": "Pivot", "refId": "C" }
      ],
      "title": "Block Download Over Time",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Rate of block header downloads per second",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "blocks/sec",
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "none"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "rate(app_fastsync_block_bestHeader_number_gauge{instance=~\"$node\"}[5m])", "legendFormat": "Headers/sec", "refId": "A" },
        { "expr": "rate(app_fastsync_block_bestFullBlock_number_gauge{instance=~\"$node\"}[5m])", "legendFormat": "Full Blocks/sec", "refId": "B" }
      ],
      "title": "Block Download Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Average time per request for headers, bodies, and receipts",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "seconds",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 7,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "rate(app_fastsync_block_downloadBlockHeaders_timer_seconds_sum{instance=~\"$node\"}[5m]) / rate(app_fastsync_block_downloadBlockHeaders_timer_seconds_count{instance=~\"$node\"}[5m])", "legendFormat": "Headers avg", "refId": "A" },
        { "expr": "rate(app_fastsync_block_downloadBlockBodies_timer_seconds_sum{instance=~\"$node\"}[5m]) / rate(app_fastsync_block_downloadBlockBodies_timer_seconds_count{instance=~\"$node\"}[5m])", "legendFormat": "Bodies avg", "refId": "B" },
        { "expr": "rate(app_fastsync_block_downloadBlockReceipts_timer_seconds_sum{instance=~\"$node\"}[5m]) / rate(app_fastsync_block_downloadBlockReceipts_timer_seconds_count{instance=~\"$node\"}[5m])", "legendFormat": "Receipts avg", "refId": "C" }
      ],
      "title": "Request Latency",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "datasource": "Prometheus",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 300,
      "panels": [],
      "title": "State Download",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "description": "State trie nodes downloaded vs total estimated",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "Nodes",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "none"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "id": 8,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "app_fastsync_state_downloadedNodes_gauge{instance=~\"$node\"}", "legendFormat": "Downloaded", "refId": "A" },
        { "expr": "app_fastsync_state_totalNodes_gauge{instance=~\"$node\"}", "legendFormat": "Total Estimated", "refId": "B" }
      ],
      "title": "State Nodes Over Time",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Rate of state node downloads",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "nodes/sec",
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "none"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "id": 9,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "rate(app_fastsync_state_downloadedNodes_gauge{instance=~\"$node\"}[5m])", "legendFormat": "Nodes/sec", "refId": "A" }
      ],
      "title": "State Download Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "datasource": "Prometheus",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 400,
      "panels": [],
      "title": "Network",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "description": "Connected and pending peers",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "Peers",
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "none"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 34 },
      "id": 10,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "app_network_peers_outgoing_handshaked_gauge{instance=~\"$node\"}", "legendFormat": "Outgoing", "refId": "A" },
        { "expr": "app_network_peers_incoming_handshaked_gauge{instance=~\"$node\"}", "legendFormat": "Incoming", "refId": "B" },
        { "expr": "app_network_peers_pending_gauge{instance=~\"$node\"}", "legendFormat": "Pending", "refId": "C" }
      ],
      "title": "Peer Count",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Blacklisted peers by group",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "Count",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "none"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 34 },
      "id": 11,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "rate(app_network_peers_blacklisted_fastSyncGroup_counter_total{instance=~\"$node\"}[5m]) * 60", "legendFormat": "FastSync/min", "refId": "A" },
        { "expr": "rate(app_network_peers_blacklisted_p2pGroup_counter_total{instance=~\"$node\"}[5m]) * 60", "legendFormat": "P2P/min", "refId": "B" }
      ],
      "title": "Blacklist Rate",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 27,
  "style": "dark",
  "tags": ["fukuii", "fastsync", "etc"],
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": "Prometheus",
        "definition": "label_values(app_fastsync_block_pivotBlock_number_gauge, instance)",
        "hide": 0,
        "includeAll": true,
        "label": "Node",
        "multi": false,
        "name": "node",
        "query": "label_values(app_fastsync_block_pivotBlock_number_gauge, instance)",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Fukuii Fast Sync",
  "uid": "fukuii-fast-sync",
  "version": 1
