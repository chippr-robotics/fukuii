      "id": 100,
      "options": {
        "content": "<div style=\"text-align:center;padding:8px 0;\">\n  <span style=\"font-size:28px;letter-spacing:4px;font-weight:200;color:#b4a7d6;\">FUKUII</span>\n  <span style=\"font-size:28px;letter-spacing:4px;font-weight:200;color:#93c47d;\"> ENGINE API</span>\n  <span style=\"font-size:28px;letter-spacing:4px;font-weight:200;color:#6fa8dc;\"> SYNC VIBES</span>\n  <br/>\n  <span style=\"font-size:12px;color:#999;letter-spacing:2px;\">consensus layer driven block execution</span>\n</div>",
        "mode": "html"
      },
      "transparent": true,
      "type": "text"
    },
    {
      "datasource": "Prometheus",
      "description": "Latest block received via Engine API newPayload",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#6fa8dc", "value": null },
              { "color": "#93c47d", "value": 1 }
            ]
          },
          "unit": "none"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 3 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Latest Block",
      "type": "stat",
      "targets": [
        {
          "expr": "app_engine_latest_payload_block{instance=~\".*fukuii.*\"}",
          "legendFormat": "block #",
          "refId": "A"
        }
      ]
    },
