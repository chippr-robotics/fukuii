    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": [],
      "title": "Node Health",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "description": "Sync status as percentage of current block vs best known network block. Green (>99%) = Synced, Yellow (95-99%) = Catching Up, Red (<95%) = Behind.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "from": 99,
                "to": 200,
                "result": {
                  "color": "#00D395",
                  "index": 0,
                  "text": "Synced"
                }
              },
              "type": "range"
            },
            {
              "options": {
                "from": 95,
                "to": 99,
                "result": {
                  "color": "#FFB357",
                  "index": 1,
                  "text": "Catching Up"
                }
              },
              "type": "range"
            },
            {
              "options": {
                "from": 0,
                "to": 95,
                "result": {
                  "color": "#F2495C",
                  "index": 2,
                  "text": "Behind"
                }
              },
              "type": "range"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#F2495C", "value": null },
              { "color": "#FFB357", "value": 95 },
              { "color": "#00D395", "value": 99 }
            ]
          },
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "pluginVersion": "9.5.0",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "clamp_max(app_sync_block_number_gauge{instance=~\"$node\"} / clamp_min(app_regularsync_block_bestKnown_number_gauge{instance=~\"$node\"}, 1) * 100, 100)",
          "legendFormat": "Sync %",
          "refId": "A"
        }
      ],
      "title": "Sync Status",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "Current synced block number",
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "#00D395",
