# Gorgoroth Multi-Client Test Network — Image Configuration
#
# Copy this file to .env (or .env.pre-olympia / .env.olympia) and adjust.
# Usage: docker compose --env-file .env -f docker-compose-3nodes.yml up -d
#
# Build images with: ../tools/build-all-images.sh <target>
#   target: pre-olympia (alpha/etc branches) or olympia (olympia branches)
#
# Image naming convention:
#   <client>-etc:<target>   — branch-specific tag
#   <client>-etc:local      — always points to the most recent build

FUKUII_IMAGE=fukuii-etc:local
COREGETH_IMAGE=coregeth-etc:local
BESU_ETC_IMAGE=besu-etc:local
