# Pre-Olympia image configuration for Gorgoroth multi-client trials
# ===================================================================
# THIS IS A TEMPLATE. Do NOT put secrets in this file.
#
# To use:
#   1. Copy this file:  cp .env.pre-olympia.example .env.pre-olympia
#   2. Edit .env.pre-olympia with your values
#   3. Verify .env.pre-olympia is in .gitignore (it should be — never commit .env files)
#
# Usage: docker compose --env-file .env.pre-olympia -f docker-compose-3nodes.yml up -d
#
# Build images first: ../tools/build-all-images.sh pre-olympia
# ===================================================================

FUKUII_IMAGE=fukuii-etc:pre-olympia
COREGETH_IMAGE=coregeth-etc:pre-olympia
BESU_ETC_IMAGE=besu-etc:pre-olympia
