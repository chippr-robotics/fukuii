# syntax=docker/dockerfile:1.4
# Development image for Fukuii builds
# This image includes JDK and SBT for development and CI/CD

FROM eclipse-temurin:21-jdk-noble

# OCI labels for container metadata
LABEL org.opencontainers.image.title="Fukuii Development Image"
LABEL org.opencontainers.image.description="Development environment for Fukuii Ethereum Client"
LABEL org.opencontainers.image.vendor="Chippr Robotics LLC"
LABEL org.opencontainers.image.source="https://github.com/chippr-robotics/fukuii"
LABEL org.opencontainers.image.documentation="https://github.com/chippr-robotics/fukuii/blob/main/docs/deployment/docker.md"

ENV DEBIAN_FRONTEND=noninteractive

# Install development tools
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        curl \
        git \
        gnupg2 \
        ca-certificates \
        unzip

# Install SBT
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    curl -sL "https://keyserver.ubuntu.com/pks/lookup?op=get&search=0x2EE0EA64E40A89B84B2DF73499E82A75642AC823" | gpg --dearmor -o /usr/share/keyrings/sbt-archive-keyring.gpg && \
    echo "deb [signed-by=/usr/share/keyrings/sbt-archive-keyring.gpg] https://repo.scala-sbt.org/scalasbt/debian all main" | tee /etc/apt/sources.list.d/sbt.list && \
    apt-get update && \
    apt-get install -y sbt

# Create non-root user and necessary directories.
# Pin uid/gid to 1000 so BuildKit cache mounts can be owned by this user
# (BuildKit cache grammar resolves uid= at build time; it can't read /etc/passwd).
# Ubuntu Noble's base image ships with a default `ubuntu` user at uid 1000;
# remove it first so we own that slot.
RUN (userdel -rf ubuntu 2>/dev/null || true) && \
    (groupdel ubuntu 2>/dev/null || true) && \
    groupadd -g 1000 fukuii && \
    useradd -u 1000 -g 1000 -m --home-dir=/home/fukuii --shell=/bin/bash fukuii && \
    mkdir -p /home/fukuii/.cache/sbt /home/fukuii/.ivy2 /home/fukuii/.sbt && \
    chown -R fukuii:fukuii /home/fukuii

USER fukuii
WORKDIR /home/fukuii
ENV USER=fukuii

# Pre-warm SBT by running a simple command. uid/gid match the fukuii user
# so the cache mount is writable by sbt (otherwise it's root-owned → EACCES).
RUN --mount=type=cache,target=/home/fukuii/.ivy2,uid=1000,gid=1000 \
    --mount=type=cache,target=/home/fukuii/.sbt,uid=1000,gid=1000 \
    --mount=type=cache,target=/home/fukuii/.cache,uid=1000,gid=1000 \
    sbt -version

CMD ["/bin/bash"]
